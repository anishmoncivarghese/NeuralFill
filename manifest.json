{
  "manifest_version": 3,
  "name": "NeuralFill",
  "version": "1.1",
  "description": "Fill any form in one click — locally. AI-powered answers, PIN-locked, zero data sent externally.",
  "permissions": [
    "storage",
    "activeTab",
    "scripting",
    "contextMenus",
    "unlimitedStorage"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "commands": {
    "fill_form": {
      "suggested_key": {
        "default": "Ctrl+Shift+F",
        "mac": "Command+Shift+F"
      },
      "description": "Fill the current form with NeuralFill"
    }
  },
  "background": {
    "service_worker": "background/background.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content/content.js"],
      "run_at": "document_end"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "utils/crypto.js",
        "utils/aiEngine.js",
        "utils/regexEngine.js",
        "utils/authManager.js",
        "utils/documentManager.js",
        "utils/ragEngine.js",
        "lib/pdf.min.js",
        "lib/pdf.worker.min.js",
        "lib/mammoth.browser.min.js",
        "content/bridge.js"
      ],
      "matches": ["<all_urls>"]
    }
  ],
  "content_security_policy": {
    "extension_pages": "script-src 'self' 'wasm-unsafe-eval'; object-src 'self'; connect-src 'none';"
  }
}
